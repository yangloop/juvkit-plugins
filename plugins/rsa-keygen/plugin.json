{
  "id": "rsa-keygen",
  "name": "RSA 密钥工具",
  "version": "1.0.0",
  "description": "RSA 密钥对生成、加密解密测试工具 - 支持 2048/3072/4096 位密钥",
  "author": "Juvkit",
  "keywords": ["rsa", "密钥", "key", "加密", "解密", "encrypt", "decrypt", "crypto"],
  "icon": "key",
