{
  "id": "weather-plugin",
  "name": "天气查询",
  "version": "2.0.0",
  "description": "查询城市天气信息，支持城市收藏",
  "author": "Plugin Developer",
  "keywords": ["天气", "weather", "气温", "forecast", "温度"],
  "icon": "🌤️",
  "entryPoint": "index.js",
  "style": "style.css",
  "template": "template.html",
  "window": { "width": 600, "height": 460 },
  "permissions": ["http:fetch", "storage", "notification"],
  "allowedHosts": ["wttr.in", "*.wttr.in"],
  "permissionLevel": "standard"
}
